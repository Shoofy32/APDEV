            <!-- New Posts and Create Thread Buttons -->
            <div class = "post_and_threads_buttons">
 
                <button onclick= "window.location.href = '../forumpage/post.html';"> <i class = "fa-solid fa-bolt" style = "color: #ffffff;"></i> New Posts </button>
                <button onclick= "window.location.href = '../forumpage/post.html';"> <i class = "fa-solid fa-square-pen fa-lg" style = "color: #ffffff;"></i> Post Thread </button>

