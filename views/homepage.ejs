        <!-- Link JS File for routes interaction -->
        <script type = "module" src = "../javascript/routes.js"></script>
        
        <!-- Link JS File for homepage interaction -->
        <script src = "../javascript/homepage.js"></script>

        <!-- Link JS File for sidebar interaction -->
